{
  "name": "love2d-typescript",
  "version": "1.0.0",
  "main": "dist/index.js",
  "author": "Jake Klassen",
  "license": "MIT",
  "type": "module",
  "imports": {
    "#app/*": "./dist/*"
  },
  "scripts": {
    "prebuild": "shx rm -rf game",
    "build": "shx rm -rf game && pnpm build:tstl && pnpm build:copy",
    "build:tstl": "tstl -p tsconfig.build.json",
    "build:copy": "shx cp -R res game",
    "build:watch": "tstl -w -p tsconfig.build.json",
    "lint": "oxlint --type-aware",
    "start": "love game --console",
    "test": "vitest"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "comment-json": "5.0.0",
    "expect": "30.4.1",
    "love-typescript-definitions": "^11.5.3",
    "lua-types": "^2.14.1",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "3.8.3",
    "shx": "0.4.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-to-lua": "^1.36.0",
    "vitest": "^4.1.8"
  }
}
